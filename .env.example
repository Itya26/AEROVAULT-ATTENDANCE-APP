# Required environment variables for the AEROVAULT Attendance API server.
# On Railway, set these under your service's "Variables" tab.

# Postgres connection string. If you add Railway's Postgres plugin to this
# project, reference it as: ${{Postgres.DATABASE_URL}}
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret used to sign employee login JWTs. Generate one with:
#   openssl rand -hex 32
SESSION_SECRET=replace-with-a-long-random-string

# Railway sets PORT automatically — do not set this manually in Railway.
# (Only needed for local/manual runs.)
PORT=5000

NODE_ENV=production
